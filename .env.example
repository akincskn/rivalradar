# ============================================================
# RivalRadar — Environment Variables
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur:
#   cp .env.example .env.local
# ============================================================

# --------------------------------------------------------
# NEON DATABASE
# Neon Dashboard > Connection Details > Connection string
# --------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# --------------------------------------------------------
# NEXTAUTH
# NEXTAUTH_SECRET: openssl rand -base64 32
# NEDEN secret: Session imzalama için zorunlu.
# --------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --------------------------------------------------------
# GOOGLE OAUTH
# Google Cloud Console > APIs & Services > Credentials
# --------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --------------------------------------------------------
# N8N
# N8N Dashboard > Workflow > Webhook Node > URL
# SECRET: openssl rand -hex 32
# --------------------------------------------------------
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_SECRET=""
